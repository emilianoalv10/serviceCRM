# Puerto HTTP (Railway lo inyecta automáticamente)
PORT=3000

# Usuario y contraseña para acceder al CRM
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esto

# Secreto de sesión (cualquier string largo y aleatorio)
SESSION_SECRET=cambia-esto-por-un-string-largo-y-aleatorio

# Ruta del archivo SQLite. En Railway apuntar a un Volume montado, ej: /data/crm.db
DB_PATH=./data/crm.db
